{
  "entities": {
    "UserData": {
      "title": "UserData",
      "description": "User's browser data including bookmarks, history, and virtual state",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "bookmarks": { "type": "array", "items": { "type": "object" } },
        "history": { "type": "array", "items": { "type": "object" } },
        "downloads": { "type": "array", "items": { "type": "object" } },
        "virtualState": { "type": "object" },
        "updatedAt": { "type": "number" }
      },
      "required": ["uid"]
    },
    "PublishedSite": {
      "title": "PublishedSite",
      "description": "A generated site published by a user to the public directory",
      "type": "object",
      "properties": {
        "url": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "publisherUid": { "type": "string" },
        "publisherName": { "type": "string" },
        "publishedAt": { "type": "number" },
        "likes": { "type": "number" }
      },
      "required": ["url", "content", "publisherUid", "publishedAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "UserData",
      "description": "User's browser data"
    },
    "published_sites/{siteId}": {
      "schema": "PublishedSite",
      "description": "Publicly shared generated sites"
    }
  }
}
